mod.wizards.newContentElement.wizardItems {
	common {
		elements {
			ps14_icon_text {
				iconIdentifier = content-textpic
				title = LLL:EXT:ps14_icon_text/Resources/Private/Language/locallang_tca.xlf:icon-text.title
				description = LLL:EXT:ps14_icon_text/Resources/Private/Language/locallang_tca.xlf:icon-text.description
				tt_content_defValues {
					CType = ps14_icon_text
				}
			}
		}

		show := addToList(ps14_icon_text)
	}
}